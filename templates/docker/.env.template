# robot distribution — child .env template.
# Copied by bootstrap-child.sh as `<child>/docker/.env`. Tracked per-child (not gitignored)
# UNLESS secrets are added — then mark `<child>/docker/.env.local` gitignored and source both.
#
# COMPOSE_PROJECT_NAME is set by bootstrap-child.sh to the child directory name.
# Overriding it breaks container_name uniqueness guarantees — edit only if you know why.

COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT_NAME}
ROS_DISTRO=humble
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_DOMAIN_ID=0
DATA_DIR=../data
ROBOT_ROOT=${ROBOT_ROOT}
