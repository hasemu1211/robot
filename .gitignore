# OMC runtime (per-session state, not tracked)
.omc/state/
.omc/sessions/
.omc/logs/
.omc/notepad.md
.omc/project-memory.json
# OMC artifacts (tracked — design records)
!.omc/specs/
!.omc/plans/
!.omc/research/

# Data outputs / caches
data/
__pycache__/
*.pyc
.cache/

# Env / secrets (user-specific, never committed)
.env
.env.local
*.local

# install.sh dotfile backups (timestamped, user-specific)
*.pre-robot.*.bak

# install.sh idempotency state (per-machine, not tracked)
.omc/state/install/

# .omc runtime logs (extension of .omc/logs/ already above)
.omc/logs/install-*.log
.omc/logs/settings-merge-*.log

# Legacy / local-only symlinks (user-specific).
# vendor/isaac-sim-mcp is now a real submodule (see .gitmodules).
/datafactory

# external/ — until submodule transition (Phase A-3)
/external/robotics-agent-skills/

# dotfiles backup files anywhere (already covered above, explicit for clarity)
*.pre-rtk.*.bak

# Node / editor runtime
node_modules/
.vscode/
.idea/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db
