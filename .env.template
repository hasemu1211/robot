# robot distribution — secrets template.
# Copy to `.env.local` (gitignored) and fill in values. install.sh reads from
# .env.local by default, or from shell env when `--env-from-shell` is passed.
#
# DO NOT COMMIT `.env.local`. `.gitignore` has `.env.local` + `*.local`.

# NGC (NVIDIA GPU Cloud) API Key — Isaac Sim 이미지 pull + nvcr.io docker login.
# 얻는 법: https://ngc.nvidia.com → Setup → Generate API Key
NGC_API_KEY=

# (선택) ROBOT_ROOT — install.sh / doctor.sh / bootstrap-child.sh가 사용.
# 미설정 시 git rev-parse --show-toplevel 으로 자동 resolve.
# 특수한 경로 (예: ~/dev/robot) 에 clone한 경우만 명시.
# ROBOT_ROOT=

# (선택 — 미래 확장) 추가 secret 예시:
# HUGGINGFACE_TOKEN=
# OPENAI_API_KEY=
# WANDB_API_KEY=
